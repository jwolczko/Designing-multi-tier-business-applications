meta {
  name: Create Transfer
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/transfers
  body: json
}

body:json {
  {
    "sourceAccountId": "{{sourceAccountId}}",
    "targetAccountId": "{{targetAccountId}}",
    "amount": {{transferAmount}},
    "currency": "{{currency}}",
    "title": "{{transferTitle}}"
  }
}

tests {
  test("transfer returns 200", function () {
    expect(res.getStatus()).to.equal(200);
  });
}
