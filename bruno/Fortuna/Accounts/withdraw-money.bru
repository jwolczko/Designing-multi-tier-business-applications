meta {
  name: Withdraw Money
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/accounts/{{accountId}}/withdraw
  body: json
}

body:json {
  {
    "amount": {{withdrawAmount}},
    "currency": "{{currency}}",
    "title": "{{withdrawTitle}}"
  }
}

tests {
  test("withdraw returns 200", function () {
    expect(res.getStatus()).to.equal(200);
  });
}
