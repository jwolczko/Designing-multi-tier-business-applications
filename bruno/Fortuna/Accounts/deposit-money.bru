meta {
  name: Deposit Money
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/accounts/{{accountId}}/deposit
  body: json
}

body:json {
  {
    "amount": {{depositAmount}},
    "currency": "{{currency}}",
    "title": "{{depositTitle}}"
  }
}

tests {
  test("deposit returns 200", function () {
    expect(res.getStatus()).to.equal(200);
  });
}
